    <sql id="selectModelingThemeDomainVo">
        select ID, CODE, NAME, ENG_NAME, PARENT_ID, OWNER_USER_ID, DATA_LAYER_ID, DESCRIPTION, VALID_FLAG, DEL_FLAG, CREATE_BY, CREATOR_ID, CREATE_TIME, UPDATE_BY, UPDATER_ID, UPDATE_TIME, REMARK from MDL_THEME_DOMAIN
    </sql>

    <select id="selectModelingThemeDomainList" parameterType="ModelingThemeDomainDO" resultMap="ModelingThemeDomainResult">
        <include refid="selectModelingThemeDomainVo"/>
        <where>
            <if test="code != null  and code != ''"> and CODE = #{code}</if>
            <if test="name != null  and name != ''"> and NAME like concat('%', #{name}, '%')</if>
            <if test="engName != null  and engName != ''"> and ENG_NAME like concat('%', #{engName}, '%')</if>
            <if test="parentId != null "> and PARENT_ID = #{parentId}</if>
            <if test="ownerUserId != null "> and OWNER_USER_ID = #{ownerUserId}</if>
            <if test="dataLayerId != null "> and DATA_LAYER_ID = #{dataLayerId}</if>
            <if test="description != null  and description != ''"> and DESCRIPTION like concat('%', #{description}, '%')</if>
            <if test="createTime != null "> and CREATE_TIME = #{createTime}</if>
        </where>
    </select>

    <select id="selectModelingThemeDomainById" parameterType="Long" resultMap="ModelingThemeDomainResult">
        <include refid="selectModelingThemeDomainVo"/>
        where ID = #{id}
    </select>

    <insert id="insertModelingThemeDomain" parameterType="ModelingThemeDomainDO">
