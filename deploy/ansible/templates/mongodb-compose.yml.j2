services:
  mongodb:
    image: {{ mongodb_image }}
    container_name: datamaster-mongodb
    restart: always
    environment:
      TZ: {{ timezone }}
      MONGO_INITDB_ROOT_USERNAME: {{ mongodb_root_user }}
      MONGO_INITDB_ROOT_PASSWORD: {{ mongodb_root_password }}
    ports:
      - "{{ mongodb_port }}:27017"
    volumes:
      - ./data:/data/db
      - ./conf:/data/configdb
      - ./logs:/var/log/mongodb
      - ./init:/docker-entrypoint-initdb.d:ro
    healthcheck:
      test: ["CMD", "mongosh", "--quiet", "--eval", "db.adminCommand('ping').ok"]
      interval: 10s
      timeout: 5s
      retries: 10
